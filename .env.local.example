# Copy to .env.local and fill in the values from your Supabase project
# (Dashboard → Project Settings → API).

# Project URL — e.g. https://xxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable key (new format `sb_publishable_...`). Safe to expose to the
# browser as long as RLS is enabled — which our schema does.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key (new format `sb_secret_...`). Server-only. Bypasses RLS.
# Used by the seed script and any admin server actions that need it.
# Never commit, never expose to the client.
SUPABASE_SECRET_KEY=sb_secret_...
