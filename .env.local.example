# Copy to .env.local and fill in the values from your Supabase project
# (Dashboard → Project Settings → API).

# Publishable values — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Secret. Server-only. Used by the seed script and any admin server actions
# that need to bypass RLS. Never commit and never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
